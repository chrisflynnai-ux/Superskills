     ═══════════════════════════════════════════════════════════════════════════════ -->

<EVIDENCE_PACK schema="EVIDENCE_PACK_v1.1" version="1.1">
  <Meta>
    <ProjectID>PB-XXXX</ProjectID>
    <Product></Product>
    <CreatedDate>YYYY-MM-DD</CreatedDate>
    <UpdatedDate>YYYY-MM-DD</UpdatedDate>
    <Owner></Owner>
    <ComplianceNotes>
      <Note>No disease claims</Note>
      <Note>No guaranteed outcomes</Note>
      <Note>Testimonials describe individual experiences</Note>
    </ComplianceNotes>
  </Meta>

  <Sources>
    <Source id="S01">
      <Type>study</Type>
      <Title></Title>
      <Author></Author>
      <Date></Date>
      <URL></URL>
      <FileRef></FileRef>
      <Reliability>high</Reliability>
      <Notes></Notes>
    </Source>
  </Sources>

  <EvidenceItems>
    <Evidence id="E01">
      <Type>study</Type>
      <SourceRef>S01</SourceRef>
      <ClaimSupported>C01</ClaimSupported>
      <Excerpt></Excerpt>
      <Interpretation></Interpretation>
      <Strength>strong</Strength>
      
      <!-- 7S Integration: Which dimension does this evidence support? -->
      <SevenSTarget>SIGNIFICANT</SevenSTarget>
      
      <AllowedLanguage>
        <Phrase>may support</Phrase>
        <Phrase>associated with</Phrase>
        <Phrase>in one study</Phrase>
      </AllowedLanguage>
      <ForbiddenLanguage>
        <Phrase>cures</Phrase>
        <Phrase>treats</Phrase>
        <Phrase>guarantees</Phrase>
      </ForbiddenLanguage>
    </Evidence>
  </EvidenceItems>

  <ProofGaps>
    <Gap id="G01">
      <ClaimNeeded>C03</ClaimNeeded>
      <SevenSDimension>SAFE</SevenSDimension>
      <WhyNeeded></WhyNeeded>
      <PlanToFill></PlanToFill>
      <Workaround></Workaround>
    </Gap>
  </ProofGaps>

  <ClaimsMap>
    <Claim id="C01">
      <Text></Text>
      <EvidenceRefs>
        <Ref>E01</Ref>
        <Ref>E02</Ref>
      </EvidenceRefs>
      <Strength>strong</Strength>
      <ActionIfWeak>soften_language</ActionIfWeak>
    </Claim>
  </ClaimsMap>

  <MMAValidation>
    <AllClaimsGrounded>false</AllClaimsGrounded>
    <UngroundedClaims></UngroundedClaims>
    <WeakClaims></WeakClaims>
    <ProofDisciplineScore>0</ProofDisciplineScore>
  </MMAValidation>
</EVIDENCE_PACK>


