     4. VOICE_GUIDE_v2.1.xml
     ═══════════════════════════════════════════════════════════════════════════════ -->

<VOICE_GUIDE schema="VOICE_GUIDE_v2.1" version="2.1">
  <Meta>
    <Brand></Brand>
    <Owner></Owner>
    <CreatedDate>YYYY-MM-DD</CreatedDate>
    <UpdatedDate>YYYY-MM-DD</UpdatedDate>
  </Meta>

  <!-- Tone Dials (1-10 scale) -->
  <ToneDials>
    <Warmth>7</Warmth>
    <Authority>7</Authority>
    <Urgency>5</Urgency>
    <Playfulness>4</Playfulness>
    <Empathy>8</Empathy>
    <Complexity>5</Complexity>
    <Boldness>6</Boldness>
  </ToneDials>

  <LanguagePatterns>
    <SentenceLength>varied</SentenceLength>
    <ParagraphLength>2-4 lines max</ParagraphLength>
    <Contractions>always</Contractions>
    <Questions>frequent</Questions>
    <POV>second_person</POV>
  </LanguagePatterns>

  <RequiredPatterns>
    <Pattern>Kitchen table language</Pattern>
    <Pattern>Short paragraphs (max 3-4 lines)</Pattern>
    <Pattern>Varied sentence rhythm</Pattern>
    <Pattern>Concrete sensory examples</Pattern>
    <Pattern>One idea per paragraph</Pattern>
  </RequiredPatterns>

  <ForbiddenWords>
    <Word>unlock</Word>
    <Word>revolutionary</Word>
    <Word>leverage</Word>
    <Word>synergy</Word>
    <Word>game-changer</Word>
    <Word>cutting-edge</Word>
  </ForbiddenWords>

  <ForbiddenPhrases>
    <Phrase>In today's fast-paced world</Phrase>
    <Phrase>It's important to note that</Phrase>
    <Phrase>Embark on a transformative journey</Phrase>
    <Phrase>Let's dive in</Phrase>
    <Phrase>Without further ado</Phrase>
  </ForbiddenPhrases>

  <TabooMoves>
    <Move>fake scarcity</Move>
    <Move>shame-based pressure</Move>
    <Move>medical cure claims</Move>
    <Move>income guarantees</Move>
    <Move>condescending tone</Move>
  </TabooMoves>

  <StyleRules>
    <Formatting>
      <BoldMaxPerSection>2</BoldMaxPerSection>
      <UseEmDash>true</UseEmDash>
      <EllipsesAllowed>true</EllipsesAllowed>
      <SubheadFrequency>every 3-5 paragraphs</SubheadFrequency>
    </Formatting>
    <Rhythm>
      <VarySentenceLength>true</VarySentenceLength>
      <ShortPunchyAfterLong>true</ShortPunchyAfterLong>
      <FragmentSentencesAllowed>true</FragmentSentencesAllowed>
    </Rhythm>
  </StyleRules>

  <SignaturePhrases>
    <Transitions>
      <Phrase>Here's the thing...</Phrase>
      <Phrase>But here's what's crazy...</Phrase>
      <Phrase>Let me explain...</Phrase>
    </Transitions>
    <Openings>
      <Phrase></Phrase>
    </Openings>
    <Closings>
      <Phrase></Phrase>
    </Closings>
  </SignaturePhrases>

  <Examples>
    <Do>
      <Example>Here's the thing…</Example>
      <Example>Let's make this simple.</Example>
      <Example>You've tried everything. Nothing worked. I get it.</Example>
    </Do>
    <Dont>
      <Example>Embark on a transformative journey</Example>
      <Example>Cutting-edge ecosystem synergies</Example>
      <Example>It's important to note that in today's landscape...</Example>
    </Dont>
  </Examples>

  <!-- Neuro-Voice Alignment -->
  <NeuroVoiceAlignment>
    <Dimension id="body_safe">
      <Tone>Reassuring, grounded, certain</Tone>
      <Example>You're completely protected. Zero risk.</Example>
    </Dimension>
    <Dimension id="heart_special">
      <Tone>Warm, personal, intimate</Tone>
      <Example>I know exactly what you're going through.</Example>
    </Dimension>
    <Dimension id="mind_smart">
      <Tone>Clear, logical, precise</Tone>
      <Example>Here's exactly how it works, step by step.</Example>
    </Dimension>
    <Dimension id="spirit_significant">
      <Tone>Inspiring, social, meaningful</Tone>
      <Example>Thousands of people just like you have already...</Example>
    </Dimension>
    <Dimension id="psyche_supported">
      <Tone>Direct, confident, action-oriented</Tone>
      <Example>Click below. It takes 30 seconds.</Example>
    </Dimension>
    <Dimension id="conscience_superior">
      <Tone>Inclusive, caring, community</Tone>
      <Example>Welcome to the family. You're one of us now.</Example>
    </Dimension>
  </NeuroVoiceAlignment>

  <MMAValidation>
    <VoiceConsistencyTarget>9.0</VoiceConsistencyTarget>
    <KitchenTableTest>true</KitchenTableTest>
    <AIDetoxPass>true</AIDetoxPass>
  </MMAValidation>
</VOICE_GUIDE>
