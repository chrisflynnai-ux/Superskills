<PROJECT_BRIEF schema="PROJECT_BRIEF_v2.1" version="2.1">
  <Meta>
    <ProjectID>PB-XXXX</ProjectID>
    <CreatedDate>YYYY-MM-DD</CreatedDate>
    <UpdatedDate>YYYY-MM-DD</UpdatedDate>
    <Owner></Owner>
  </Meta>

  <Objective>
    <PrimaryGoal></PrimaryGoal>
    <SuccessMetrics>
      <Metric name="CTR" target=""/>
      <Metric name="CVR" target=""/>
      <Metric name="AOV" target=""/>
    </SuccessMetrics>
  </Objective>

  <Avatar>
    <Name></Name>
    <AwarenessStage>Problem-Aware</AwarenessStage>
    <TrafficTemperature>cold</TrafficTemperature>
    <Pains>
      <Pain></Pain>
    </Pains>
    <Desires>
      <Desire></Desire>
    </Desires>
    <Objections>
      <Objection></Objection>
    </Objections>
  </Avatar>

  <Offer>
    <Name></Name>
    <Type>core</Type>
    <Price></Price>
    <Guarantee></Guarantee>
    <Transformation>
      <Before></Before>
      <After></After>
      <Timeframe></Timeframe>
    </Transformation>
  </Offer>

  <Deliverables>
    <Item type="advertorial" priority="P1"/>
    <Item type="sales_page" priority="P1"/>
    <Item type="email_sequence" priority="P2"/>
  </Deliverables>

  <Constraints>
    <Compliance>
      <Rule>No fake scarcity</Rule>
      <Rule>No claims beyond EVIDENCE_PACK</Rule>
    </Compliance>
    <Brand>
      <Rule>Tone must match VOICE_GUIDE</Rule>
    </Brand>
    <Platform name="">
      <Restriction></Restriction>
    </Platform>
  </Constraints>

  <!-- 7S Focus: Which dimensions are primary for this project -->
  <SevenSFocus>
    <Primary>SAFE</Primary>
    <Primary>SMART</Primary>
    <Secondary>SPECIAL</Secondary>
    <Secondary>SIGNIFICANT</Secondary>
    <Notes></Notes>
  </SevenSFocus>

  <Inputs>
    <Required>
      <Item>MESSAGE_SPINE</Item>
    </Required>
    <Optional>
      <Item>EVIDENCE_PACK</Item>
      <Item>VOICE_GUIDE</Item>
    </Optional>
  </Inputs>
</PROJECT_BRIEF>


